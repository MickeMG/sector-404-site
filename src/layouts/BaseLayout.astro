---
const { title = 'SECTOR 404', description = 'An archive of objects, stories and transmissions.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="stylesheet" href={`${base}styles/global.css`} />
  </head>
  <body>
    <header class="site-header">
      <a class="mark" href={base}>SECTOR 404</a>
      <nav>
        <a href={`${base}works/`}>Works</a>
        <a href={`${base}world/`}>World</a>
        <a href={`${base}characters/`}>Characters</a>
        <a href={`${base}stories/`}>Stories</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
