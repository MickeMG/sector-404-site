---
const { title = 'SECTOR 404', description = 'An unlisted access point for unauthorized artifacts, infected signals and recovered transmissions that should not be visible from the outside.' } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const assetVersion = 'linked-images-skip-inspector-r1';
const versioned = (path: string) => `${base}${path}?v=${assetVersion}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#020405" />
    <title>{title}</title>
    <link rel="stylesheet" href={versioned('styles/global.css')} />
    <script is:inline>
      document.documentElement.classList.add('access-gate-pending');
      try {
        localStorage.removeItem('sector404_access_user');
        sessionStorage.removeItem('sector404_access_user');
      } catch (_) {}
    </script>
    <script src={versioned('access-gate.js')} defer></script>
    <script src={versioned('home-breach.js')} defer></script>
    <script src={versioned('image-inspector.js')} defer></script>
    <script src={versioned('audio-player.js')} defer></script>
  </head>
  <body>
    <div class="breach-boot" data-breach-boot aria-hidden="true">
      <div class="breach-boot__panel">
        <p>RPI BLACK CHANNEL / RECOVERED HANDSHAKE</p>
        <span data-breach-line></span>
        <span data-breach-line></span>
        <span data-breach-line></span>
        <span data-breach-line></span>
        <span data-breach-line></span>
        <span data-breach-line></span>
        <span data-breach-line></span>
      </div>
      <div class="breach-boot__connected" data-breach-connected aria-hidden="true">CONNECTED</div>
    </div>
    <div class="site-shell">
      <div class="skin-layer" aria-hidden="true">
        <span class="skin-scrap"></span>
        <span class="skin-salvage"></span>
        <span class="skin-shrine"></span>
        <span class="skin-mask"></span>
      </div>
      <div class="system-hud" aria-hidden="true">
        <span>RPI_DENIAL_LAYER</span>
        <span>UNINVITED_ACCESS</span>
        <span>TRACE DEGRADED</span>
      </div>
      <header class="site-header">
        <a class="mark" href={base}>SECTOR 404</a>
        <div class="sector-player" data-sector-player data-playlist-url={`${base}assets/audio/julian/playlist.json`} aria-label="Julian audio player">
          <audio data-player-audio preload="metadata"></audio>
          <span class="sector-player__signal" aria-hidden="true"></span>
          <div class="sector-player__readout">
            <span class="sector-player__label">JULIAN_AUDIO</span>
            <span class="sector-player__title" data-player-title>AWAITING JULIAN MP3</span>
            <span class="sector-player__status" data-player-status>NO SIGNAL</span>
          </div>
          <div class="sector-player__controls">
            <button type="button" data-player-prev aria-label="Previous Julian track" title="Previous Julian track">◀◀</button>
            <button type="button" data-player-play aria-label="Play or stop Julian track" title="Play or stop Julian track">▶</button>
            <button type="button" data-player-next aria-label="Next Julian track" title="Next Julian track">▶▶</button>
            <button type="button" data-player-mute aria-label="Mute or unmute Julian audio" title="Mute or unmute Julian audio">◉</button>
          </div>
        </div>
        <nav aria-label="Primary navigation">
          <a href={`${base}works/`} data-text="Artifacts"><span>Artifacts</span></a>
          <a href={`${base}signals/`} data-text="Signals"><span>Signals</span></a>
          <a href={`${base}world/`} data-text="Archive"><span>Archive</span></a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="footer">
        <span>RACHELL POST INDUSTRIES // IF ASKED, THIS PLACE DOES NOT EXIST</span>
        <span>404: YOUR TRACE WAS NOT FULLY REMOVED</span>
      </footer>
    </div>
  </body>
</html>
