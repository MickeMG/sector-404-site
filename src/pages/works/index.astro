---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const works = await getCollection('works');
---
<BaseLayout title="Artifacts — SECTOR 404" description="Recovered objects, physical works and contaminated artifacts surfaced through an access point that should not be public.">
  <section class="hero small portal page-hero artifacts-hero">
    <div class="breach-frame" aria-hidden="true">
      <span>MANIFEST/EXTERNAL</span>
      <span>TRANSFER NOT CLEAN</span>
      <span>OBJECTS REMEMBER</span>
    </div>
    <div class="hero-copy">
      <p class="terminal-label">Manifest opened without clearance</p>
      <h1 data-text="ARTIFACTS">ARTIFACTS</h1>
      <p class="lead">These are not products lined up for browsing. They are physical files, recovered surfaces and objects that kept enough damage to become evidence.</p>
    </div>
  </section>
  <section class="section">
    <div class="section-head">
      <div>
        <p class="kicker">External transfer manifest</p>
        <h2>If you take something from here, it takes a room inside your world.</h2>
      </div>
      <p class="muted">Acquire means: accept the file into your room and stop pretending it is only decoration.</p>
    </div>
    <div class="grid wide">
      {works.map((work, index) => (
        <article class={`card artifact-card ${work.data.cover ? 'has-cover' : ''}`} data-code={`ART_${String(index + 1).padStart(3, '0')}`}>
          <a href={`${work.id}/`}>
            {work.data.cover && (
              <span class="artifact-card-cover" aria-hidden="true">
                <img src={work.data.cover} alt="" loading="lazy" />
              </span>
            )}
            <span class="kicker">{work.data.status === 'sold' ? 'Removed from circulation' : work.data.status}</span>
            <h2>{work.data.title}</h2>
            <p class="muted">{work.data.medium || 'Artifact file pending'}</p>
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="section portal-grid artifact-skin artifact-feed-grid">
    <article class="panel copy-block">
      <p class="kicker">Material protocol</p>
      <h2>Julian samples the waste stream before it is sanitized.</h2>
      <p>RPI throws away failed futures: robotic limbs, synthetic interfaces, dead lenses, sealed components, bodies that stopped being useful. SECTOR 404 keeps the dirt on them.</p>
    </article>
    <article class="panel video-panel artifact-feed" aria-label="Cyberhead artifact feed">
      <video autoplay muted loop playsinline preload="metadata" poster="/sector-404-site/assets/sector404/video/cyberhead-artifact-feed-poster.jpg">
        <source src="/sector-404-site/assets/sector404/video/cyberhead-artifact-feed.mp4" type="video/mp4" />
      </video>
      <span>CAMERA FEED // CYBERHEAD RESIDUE</span>
    </article>
    <article class="panel artifact-collage" aria-label="RPI waste stream collage">
      <span class="tile scrap"></span>
      <span class="tile salvage"></span>
      <span class="tile shrine"></span>
    </article>
  </section>
</BaseLayout>
